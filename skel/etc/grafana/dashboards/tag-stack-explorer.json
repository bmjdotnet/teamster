          "rawSql": "SELECT\n    $__timeGroupAlias(cr.timestamp, $agg),\n    CASE WHEN cr.entity_type = '' THEN '(unallocated)' ELSE COALESCE(x1.tag_value, '(untagged)') END AS metric,\n    ROUND(SUM(cr.cost_usd * COALESCE(x1.w, 1)), 4) AS cost_usd\nFROM cost_facts cr\nLEFT JOIN (SELECT er.entity_type, er.entity_id, t.tag_value,\n           1.0 / COUNT(*) OVER (PARTITION BY er.entity_type, er.entity_id) AS w\n    FROM entity_tags_resolved er JOIN tags t ON t.id = er.tag_id\n    WHERE t.tag_key = '$stack_level_1') x1\n  ON x1.entity_type = cr.entity_type AND x1.entity_id = cr.entity_id\nWHERE $__timeFilter(cr.timestamp)\nGROUP BY 1, CASE WHEN cr.entity_type = '' THEN '(unallocated)' ELSE COALESCE(x1.tag_value, '(untagged)') END\nORDER BY 1, metric",
          "refId": "A"
        }
