          "format": "table",
          "rawSql": "SELECT\n    CASE WHEN cr.entity_type = '' THEN '(unallocated)' ELSE COALESCE(x1.tag_value, '(untagged)') END AS level_1,\n    CASE WHEN cr.entity_type = '' THEN '(unallocated)' ELSE COALESCE(x2.tag_value, '(untagged)') END AS level_2,\n    ROUND(SUM(cr.cost_usd * COALESCE(x1.w, 1) * COALESCE(x2.w, 1)), 4) AS cost_usd\nFROM cost_facts cr\nLEFT JOIN (SELECT er.entity_type, er.entity_id, t.tag_value,\n           1.0 / COUNT(*) OVER (PARTITION BY er.entity_type, er.entity_id) AS w\n    FROM entity_tags_resolved er JOIN tags t ON t.id = er.tag_id\n    WHERE t.tag_key = '$stack_level_1') x1\n  ON x1.entity_type = cr.entity_type AND x1.entity_id = cr.entity_id\nLEFT JOIN (SELECT er.entity_type, er.entity_id, t.tag_value,\n           1.0 / COUNT(*) OVER (PARTITION BY er.entity_type, er.entity_id) AS w\n    FROM entity_tags_resolved er JOIN tags t ON t.id = er.tag_id\n    WHERE t.tag_key = '$stack_level_2') x2\n  ON x2.entity_type = cr.entity_type AND x2.entity_id = cr.entity_id\nWHERE $__timeFilter(cr.timestamp)\nGROUP BY level_1, level_2\nORDER BY level_1, cost_usd DESC\nLIMIT 500",
