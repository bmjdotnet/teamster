    {
      "datasource": {
        "type": "mysql",
        "uid": "teamster-mysql"
      },
      "description": "Cost grouped by the selected tag stack levels. All cost is included. Cost with no WMS focus entity (entity_type='') appears as '(unallocated)' \u2014 no entity exists, so no tag can apply; this is an attribution gap, not a tagging gap. Cost whose entity exists but has no value for a level's key appears as '(untagged)'. Entities with multiple values for a key have their cost split evenly across the values (1/n weights), so the panel total always reconciles with Total Cost. Note: not all tag dimensions co-occur \u2014 e.g. product-tagged cost is rarely also work-type-tagged, so a large '(untagged)' share at Level 2 reflects real low overlap, not missing data. Pick Level 1/Level 2 keys that share entities (e.g. work-type \u2192 phase) for a dense stack.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 111,
      "options": {
        "barRadius": 0,
        "barWidth": 0.6,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "sortBy": "Total",
          "sortDesc": true
        },
        "orientation": "horizontal",
        "showValue": "never",
        "stacking": "normal",
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        },
        "xField": "level_1\\level_2",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100
      },
      "pluginVersion": "12.1.1",
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n    CASE WHEN cr.entity_type = '' THEN '(unallocated)' ELSE COALESCE(x1.tag_value, '(untagged)') END AS level_1,\n    CASE WHEN cr.entity_type = '' THEN '(unallocated)' ELSE COALESCE(x2.tag_value, '(untagged)') END AS level_2,\n    ROUND(SUM(cr.cost_usd * COALESCE(x1.w, 1) * COALESCE(x2.w, 1)), 4) AS cost_usd\nFROM cost_facts cr\nLEFT JOIN (SELECT er.entity_type, er.entity_id, t.tag_value,\n           1.0 / COUNT(*) OVER (PARTITION BY er.entity_type, er.entity_id) AS w\n    FROM entity_tags_resolved er JOIN tags t ON t.id = er.tag_id\n    WHERE t.tag_key = '$stack_level_1') x1\n  ON x1.entity_type = cr.entity_type AND x1.entity_id = cr.entity_id\nLEFT JOIN (SELECT er.entity_type, er.entity_id, t.tag_value,\n           1.0 / COUNT(*) OVER (PARTITION BY er.entity_type, er.entity_id) AS w\n    FROM entity_tags_resolved er JOIN tags t ON t.id = er.tag_id\n    WHERE t.tag_key = '$stack_level_2') x2\n  ON x2.entity_type = cr.entity_type AND x2.entity_id = cr.entity_id\nWHERE $__timeFilter(cr.timestamp)\nGROUP BY level_1, level_2\nORDER BY level_1, level_2 ASC\nLIMIT 500",
          "refId": "A"
        }
      ],
      "title": "Cost by $stack_level_1 \u2192 $stack_level_2 (stacked bars)",
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "level_2",
            "emptyValue": "zero",
            "rowField": "level_1",
            "valueField": "cost_usd"
          }
        }
      ],
      "type": "barchart"
    },
