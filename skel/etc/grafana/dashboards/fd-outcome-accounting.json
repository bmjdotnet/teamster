      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n  COALESCE(t.tag_value,\n    IF(cf.entity_type = '', '(unallocated)', '(untagged)')) AS work_type,\n  ROUND(SUM(cf.cost_usd * COALESCE(w.frac, 1)), 2) AS cost_usd\nFROM cost_facts cf\nLEFT JOIN (\n  SELECT etr.entity_type, etr.entity_id, etr.tag_id,\n    1 / COUNT(*) OVER (PARTITION BY etr.entity_type, etr.entity_id) AS frac\n  FROM entity_tags_resolved etr\n  JOIN tags tt ON tt.id = etr.tag_id AND tt.tag_key = 'work-type'\n) w ON w.entity_type = cf.entity_type AND w.entity_id = cf.entity_id\nLEFT JOIN tags t ON t.id = w.tag_id\nWHERE cf.timestamp BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY work_type\nORDER BY cost_usd DESC",
          "refId": "A"
        }
      ],
      "title": "Work-Type Mix (attributed spend)",
