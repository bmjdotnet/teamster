          "format": "table",
          "rawSql": "WITH wu_cost AS (\n  SELECT\n    cf.entity_id,\n    COUNT(DISTINCT cf.message_id) AS messages,\n    ROUND(SUM(cf.cost_usd), 4) AS cost_usd\n  FROM cost_facts cf\n  JOIN workunits wu ON wu.id = cf.entity_id AND cf.entity_type = 'workunit'\n  WHERE cf.timestamp BETWEEN $__timeFrom() AND $__timeTo()\n    AND ('$outcome' = 'All' OR wu.outcome_id = '$outcome')\n  GROUP BY cf.entity_id\n),\nwu_intervals AS (\n  SELECT entity_id,\n    GROUP_CONCAT(DISTINCT phase ORDER BY phase SEPARATOR '/') AS phase_str,\n    ROUND(SUM(duration_ms) / 3600000.0, 1) AS duration_hrs\n  FROM wms_intervals\n  WHERE entity_type = 'workunit' AND assembled_at IS NOT NULL\n  GROUP BY entity_id\n),\nwu_engineer AS (\n  SELECT cf.entity_id,\n    GROUP_CONCAT(DISTINCT CASE WHEN tl.username = '' THEN '(unstamped)' ELSE tl.username END SEPARATOR ', ') AS engineer\n  FROM cost_facts cf\n  JOIN token_ledger tl ON tl.message_id = cf.message_id\n  WHERE cf.entity_type = 'workunit'\n    AND cf.timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  GROUP BY cf.entity_id\n)\nSELECT\n  COALESCE(wu.title, wc.entity_id) AS work_unit,\n  COALESCE(we.engineer, '(unstamped)') AS engineer,\n  CASE WHEN wu.agent_id = '' THEN '(lead)' ELSE wu.agent_id END AS agent,\n  wu.status,\n  COALESCE(wi.phase_str, '') AS phase_mix,\n  COALESCE(wi.duration_hrs, 0) AS duration_hrs,\n  wc.messages,\n  wc.cost_usd\nFROM wu_cost wc\nJOIN workunits wu ON wu.id = wc.entity_id\nLEFT JOIN wu_intervals wi ON wi.entity_id = wc.entity_id\nLEFT JOIN wu_engineer we ON we.entity_id = wc.entity_id\nORDER BY wc.cost_usd DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Workunit Line Items for $outcome",
      "type": "table"
