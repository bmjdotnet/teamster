      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n  CASE\n    WHEN ua.method = 'temporal_join' THEN 'direct'\n    WHEN ua.method LIKE 'temporal_join%' THEN 'inferred'\n    WHEN ua.method IN ('transcript_focus_recovery','admin_warmup','gap_recovery','synthesized_outcome') THEN 'recovered'\n    ELSE 'unallocated'\n  END AS confidence,\n  COUNT(*) AS count\nFROM usage_attribution ua\nJOIN token_ledger tl ON tl.message_id = ua.message_id\nWHERE tl.timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  AND tl.timestamp < NOW() - INTERVAL 24 HOUR\nGROUP BY confidence\nORDER BY FIELD(confidence, 'direct','inferred','recovered','unallocated')",
          "refId": "A"
        }
      ],
      "title": "Attribution Confidence",
      "type": "piechart"
    },
