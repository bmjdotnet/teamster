      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "rawSql": "WITH cost_agg AS (\n  SELECT\n    cf.entity_id,\n    COUNT(DISTINCT cf.message_id) AS messages,\n    SUM(cf.tokens) AS tokens,\n    ROUND(SUM(cf.cost_usd), 4) AS cost_usd,\n    MIN(DATE(cf.timestamp)) AS first_activity,\n    MAX(DATE(cf.timestamp)) AS last_activity\n  FROM cost_facts cf\n  WHERE cf.timestamp BETWEEN $__timeFrom() AND $__timeTo()\n    AND cf.entity_type = 'outcome'\n  GROUP BY cf.entity_id\n),\nconf AS (\n  SELECT\n    ua.entity_id,\n    ROUND(100.0 * SUM(CASE WHEN ua.method LIKE 'temporal_join%' THEN 1 ELSE 0 END) / COUNT(*), 1) AS confidence_pct\n  FROM usage_attribution ua\n  JOIN token_ledger tl ON tl.message_id = ua.message_id\n  WHERE tl.timestamp BETWEEN $__timeFrom() AND $__timeTo()\n    AND ua.entity_type = 'outcome'\n  GROUP BY ua.entity_id\n),\nprod AS (\n  SELECT etr.entity_id, MAX(t.tag_value) AS product\n  FROM entity_tags_resolved etr\n  JOIN tags t ON t.id = etr.tag_id AND t.tag_key = 'product'\n  WHERE etr.entity_type = 'outcome'\n  GROUP BY etr.entity_id\n),\nres AS (\n  SELECT etr.entity_id, MAX(t.tag_value) AS resolution\n  FROM entity_tags_resolved etr\n  JOIN tags t ON t.id = etr.tag_id AND t.tag_key = 'resolution'\n  WHERE etr.entity_type = 'outcome'\n  GROUP BY etr.entity_id\n)\nSELECT\n  COALESCE(o.title, ca.entity_id) AS outcome,\n  COALESCE(p.product, '(untagged)') AS product,\n  o.status,\n  COALESCE(r.resolution, '') AS resolution,\n  ca.first_activity,\n  ca.last_activity,\n  ca.messages,\n  ca.tokens,\n  ca.cost_usd,\n  COALESCE(c.confidence_pct, 0) AS confidence_pct\nFROM cost_agg ca\nJOIN outcomes o ON o.id = ca.entity_id\nLEFT JOIN prod p ON p.entity_id = ca.entity_id\nLEFT JOIN res r ON r.entity_id = ca.entity_id\nLEFT JOIN conf c ON c.entity_id = ca.entity_id\nWHERE COALESCE(p.product, '(untagged)') IN (${product:sqlstring})\n  AND o.status IN (${status:sqlstring})\nORDER BY ca.cost_usd DESC\nLIMIT 200",
          "refId": "A"
        }
      ],
      "title": "Outcome Ledger (attributed spend, sorted by cost)",
      "type": "table"
    }
