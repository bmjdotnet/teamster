          "format": "time_series",
          "rawSql": "SELECT\n  $__timeGroupAlias(cf.timestamp, $agg),\n  CASE\n    WHEN '$outcome' != 'All' THEN COALESCE(o.title, cf.entity_id)\n    WHEN rnk.rn <= 12 THEN COALESCE(o.title, cf.entity_id)\n    ELSE '(other)'\n  END AS metric,\n  ROUND(SUM(cf.cost_usd), 4) AS cost_usd\nFROM cost_facts cf\nJOIN outcomes o ON o.id = cf.entity_id AND cf.entity_type = 'outcome'\nLEFT JOIN (\n  SELECT entity_id, ROW_NUMBER() OVER (ORDER BY SUM(cost_usd) DESC) AS rn\n  FROM cost_facts\n  WHERE timestamp BETWEEN $__timeFrom() AND $__timeTo()\n    AND entity_type = 'outcome'\n  GROUP BY entity_id\n) rnk ON rnk.entity_id = cf.entity_id\nWHERE cf.timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  AND cf.entity_type = 'outcome'\n  AND ('$outcome' = 'All' OR cf.entity_id = '$outcome')\nGROUP BY 1, metric\nORDER BY 1",
