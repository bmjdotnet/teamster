          "rawSql": "SELECT\n  CASE\n    WHEN ua.method = 'temporal_join' THEN 'direct'\n    WHEN ua.method LIKE 'temporal_join%' THEN 'inferred'\n    WHEN ua.method IN ('transcript_focus_recovery','admin_warmup','gap_recovery','synthesized_outcome') THEN 'recovered'\n    ELSE 'unallocated'\n  END AS confidence,\n  ua.method AS method,\n  COUNT(*) AS messages,\n  ROUND(SUM(tl.cost_usd), 2) AS cost_usd,\n  ROUND(100.0 * COUNT(*) / SUM(COUNT(*)) OVER (), 1) AS pct\nFROM usage_attribution ua\nJOIN token_ledger tl ON tl.message_id = ua.message_id\nWHERE tl.timestamp BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY confidence, ua.method\nORDER BY cost_usd DESC",
