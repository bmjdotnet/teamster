          "rawSql": "SELECT\n  $__timeGroupAlias(cr.timestamp, $agg),\n  COALESCE(x.tag_value, 'untagged') AS metric,\n  ROUND(SUM(cr.cost_usd), 4) AS cost_usd\nFROM cost_facts cr\nINNER JOIN (\n  SELECT entity_type, entity_id, tag_value FROM (\n    SELECT er.entity_type, er.entity_id, t.tag_value,\n           ROW_NUMBER() OVER (PARTITION BY er.entity_type, er.entity_id ORDER BY t.tag_value) rn\n    FROM entity_tags_resolved er JOIN tags t ON t.id = er.tag_id\n    WHERE t.tag_key = '$tag_key'\n  ) z WHERE rn = 1\n) x ON x.entity_type = cr.entity_type AND x.entity_id = cr.entity_id\nWHERE $__timeFilter(cr.timestamp)\nGROUP BY 1, x.tag_value\nORDER BY 1, x.tag_value",
