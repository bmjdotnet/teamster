      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT\n  COALESCE(o.title, ocr.outcome_id) AS outcome,\n  CASE\n    WHEN ocr.source_type = 'direct' THEN '  \u21b3 (direct)'\n    ELSE CONCAT('  \u21b3 ', COALESCE(w.title, ocr.source_id))\n  END AS source,\n  ocr.source_type,\n  ROUND(SUM(ocr.cost_usd), 2) AS cost_usd,\n  ROUND(SUM(ocr.tokens)) AS tokens\nFROM outcome_cost_rollup ocr\nLEFT JOIN outcomes o ON o.id = ocr.outcome_id\nLEFT JOIN workunits w ON w.id = ocr.source_id AND ocr.source_type = 'workunit'\nWHERE ocr.bucket_hour BETWEEN $__timeFrom() AND $__timeTo()\n  AND (('${filter_value:raw}' = 'All' OR '${filter_value:raw}' = '\\$__all' OR '${filter_value:raw}' = '') OR EXISTS (SELECT 1 FROM entity_tags ef JOIN tags tf ON tf.id = ef.tag_id WHERE ef.entity_type = 'outcome' AND ef.entity_id = ocr.outcome_id AND tf.tag_key = '${filter_key:raw}' AND tf.tag_value = '${filter_value:raw}'))\nGROUP BY ocr.outcome_id, o.title, ocr.source_type, ocr.source_id, w.title\nORDER BY ocr.outcome_id, ocr.source_type DESC, cost_usd DESC"
        }
      ],
      "title": "Outcome \u2192 Source Breakdown",
