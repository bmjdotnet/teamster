      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "time_series",
          "refId": "A",
          "rawSql": "SELECT\n  $__timeGroupAlias(ocr.bucket_hour, $agg),\n  CASE\n    WHEN ocr.source_type = 'direct' THEN '(direct outcome)'\n    ELSE COALESCE(w.title, ocr.source_id)\n  END AS metric,\n  ROUND(SUM(ocr.cost_usd), 4) AS value\nFROM outcome_cost_rollup ocr\nLEFT JOIN workunits w ON w.id = ocr.source_id AND ocr.source_type = 'workunit'\nWHERE ocr.bucket_hour BETWEEN $__timeFrom() AND $__timeTo()\n  AND (('${filter_value:raw}' = 'All' OR '${filter_value:raw}' = '\\$__all' OR '${filter_value:raw}' = '') OR EXISTS (SELECT 1 FROM entity_tags ef JOIN tags tf ON tf.id = ef.tag_id WHERE ef.entity_type = 'outcome' AND ef.entity_id = ocr.outcome_id AND tf.tag_key = '${filter_key:raw}' AND tf.tag_value = '${filter_value:raw}'))\nGROUP BY 1, ocr.source_type, ocr.source_id, w.title\nORDER BY 1"
        }
