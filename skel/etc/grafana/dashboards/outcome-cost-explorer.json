      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT\n  COALESCE(o.title, ocr.outcome_id) AS outcome,\n  COALESCE(o.status, '') AS status,\n  COUNT(DISTINCT CASE WHEN ocr.source_type = 'workunit' THEN ocr.source_id END) AS workunits,\n  ROUND(SUM(ocr.cost_usd), 2) AS total_cost,\n  ROUND(SUM(CASE WHEN ocr.source_type = 'direct' THEN ocr.cost_usd ELSE 0 END), 2) AS direct_cost,\n  ROUND(SUM(CASE WHEN ocr.source_type = 'workunit' THEN ocr.cost_usd ELSE 0 END), 2) AS workunit_cost,\n  ROUND(SUM(CASE WHEN ocr.source_type = 'direct' THEN ocr.cost_usd ELSE 0 END) / NULLIF(SUM(ocr.cost_usd), 0), 4) AS direct_pct\nFROM outcome_cost_rollup ocr\nLEFT JOIN outcomes o ON o.id = ocr.outcome_id\nWHERE ocr.bucket_hour BETWEEN $__timeFrom() AND $__timeTo()\n  AND (('${filter_value:raw}' = 'All' OR '${filter_value:raw}' = '\\$__all' OR '${filter_value:raw}' = '') OR EXISTS (SELECT 1 FROM entity_tags ef JOIN tags tf ON tf.id = ef.tag_id WHERE ef.entity_type = 'outcome' AND ef.entity_id = ocr.outcome_id AND tf.tag_key = '${filter_key:raw}' AND tf.tag_value = '${filter_value:raw}'))\nGROUP BY ocr.outcome_id, o.title, o.status\nORDER BY total_cost DESC\nLIMIT 100"
        }
      ],
