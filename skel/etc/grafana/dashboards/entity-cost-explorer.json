      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "time_series",
          "rawSql": "SELECT\n    $__timeGroupAlias(cr.timestamp, $agg),\n    CASE\n        WHEN cr.entity_type = 'outcome' THEN COALESCE(o.title, cr.entity_id)\n        WHEN cr.entity_type = 'workunit' THEN COALESCE(wu.title, cr.entity_id)\n        ELSE CONCAT('(legacy ', cr.entity_type, ') ', cr.entity_id)\n      END AS metric,\n    SUM(cr.cost_usd) AS cost_usd\nFROM cost_facts cr\nLEFT JOIN outcomes o ON o.id = cr.entity_id AND cr.entity_type = 'outcome'\nLEFT JOIN workunits wu ON wu.id = cr.entity_id AND cr.entity_type = 'workunit'\nWHERE $__timeFilter(cr.timestamp)\n  AND cr.entity_type != '' AND ('$entity_type' = 'all' OR cr.entity_type = '$entity_type')\nGROUP BY 1, cr.entity_type, cr.entity_id\nORDER BY 1, cr.entity_type, cr.entity_id",
          "refId": "A"
        }
      ],
      "title": "Cost Over Time by  ${entity_type:text} ",
      "type": "timeseries"
    },
