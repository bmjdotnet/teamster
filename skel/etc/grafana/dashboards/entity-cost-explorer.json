        "editorMode": "code",
        "followTheme": true,
        "gaode": {
          "key": "",
          "plugin": "AMap.Scale,AMap.ToolBar"
        },
        "getOption": "// Entity Cost Treemap — rectangles sized by cost, colored by status.\n// Data: one table-format series with fields entity, status, cost_usd (see panel target).\nconst s = context.panel.data.series[0];\nif (!s) { return { series: [] }; }\nconst f = (name) => {\n  const fld = s.fields.find((x) => x.name === name);\n  const v = fld ? fld.values : [];\n  return v.buffer || v;\n};\nconst names = f('entity');\nconst statuses = f('status');\nconst costs = f('cost_usd');\n// Status -> color, consistent with the Entity Cost Table (panel 11) and the locked convention.\nconst colorOf = {\n  done: '#73bf69',        // green\n  active: '#5794f2',      // blue\n  blocked: '#f2495c',     // red\n  review: '#fade2a',      // yellow\n  pending: '#8e8e8e',     // gray\n  unallocated: '#484f58', // gray-demote\n  legacy: '#484f58',      // gray-demote\n  unknown: '#8e8e8e',\n};\nconst data = names.map((name, i) => ({\n  name: name,\n  value: costs[i],\n  itemStyle: { color: colorOf[statuses[i]] || '#8e8e8e', borderColor: 'rgba(0,0,0,0.35)', gapWidth: 1 },\n}));\nreturn {\n  tooltip: {\n    formatter: (p) => p.name + '<br/>$' + Number(p.value).toFixed(0),\n  },\n  series: [{\n    type: 'treemap',\n    roam: false,\n    nodeClick: false,\n    breadcrumb: { show: false },\n    label: { show: true, formatter: '{b}', overflow: 'truncate', color: '#fff', fontSize: 11 },\n    upperLabel: { show: false },\n    data: data,\n  }],\n};\n",
        "google": {
          "callback": "gmapReady",
          "key": ""
        },
        "map": "none",
        "renderer": "canvas",
        "themeEditor": {
          "config": "{}",
          "name": "default"
        },
        "visualEditor": {
          "code": "return {}",
          "dataset": [],
          "series": []
        }
      },
      "pluginVersion": "7.2.2",
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n    CASE\n        WHEN cr.entity_type = '' THEN '(unallocated)'\n        WHEN cr.entity_type = 'outcome' THEN COALESCE(o.title, cr.entity_id)\n        WHEN cr.entity_type = 'workunit' THEN COALESCE(wu.title, cr.entity_id)\n        ELSE CONCAT('(legacy ', cr.entity_type, ') ', cr.entity_id)\n    END AS entity,\n    CASE\n        WHEN cr.entity_type = '' THEN 'unallocated'\n        WHEN cr.entity_type IN ('outcome','workunit') THEN COALESCE(NULLIF(COALESCE(o.status, wu.status), ''), 'unknown')\n        ELSE 'legacy'\n    END AS status,\n    ROUND(SUM(cr.cost_usd), 4) AS cost_usd\nFROM cost_facts cr\nLEFT JOIN outcomes o ON o.id = cr.entity_id AND cr.entity_type = 'outcome'\nLEFT JOIN workunits wu ON wu.id = cr.entity_id AND cr.entity_type = 'workunit'\nWHERE $__timeFilter(cr.timestamp)\n  AND cr.entity_type != '' AND ('$entity_type' = 'all' OR cr.entity_type = '$entity_type')\nGROUP BY cr.entity_type, cr.entity_id\nHAVING cost_usd > 0\nORDER BY cost_usd DESC\nLIMIT 40",
          "refId": "A"
        }
      ],
      "title": "Work Entity Cost Treemap",
      "type": "volkovlabs-echarts-panel"
