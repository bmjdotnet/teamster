          "rawSql": "SELECT\n  COALESCE(NULLIF(wi.agent_name, ''), '(lead)') AS agent,\n  COALESCE(NULLIF(s.username, ''), '(unstamped)') AS engineer,\n  COALESCE(o.title, wu.title, wi.entity_id) AS entity,\n  COALESCE(s.focus, '(no focus set)') AS focus,\n  ROUND(TIMESTAMPDIFF(SECOND, wi.started_at, NOW()) / 60, 0) AS since_min\nFROM wms_intervals wi\nLEFT JOIN sessions s ON s.session_id = wi.session_id AND s.agent_name = wi.agent_name\nLEFT JOIN outcomes o ON wi.entity_type = 'outcome' AND wi.entity_id = o.id\nLEFT JOIN workunits wu ON wi.entity_type = 'workunit' AND wi.entity_id = wu.id\nWHERE wi.ended_at IS NULL\n  AND wi.started_at > DATE_SUB(NOW(), INTERVAL 4 HOUR)\nORDER BY wi.started_at DESC\nLIMIT 20",
