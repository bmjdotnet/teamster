          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n  COALESCE(t.tag_value, IF(cf.entity_type = '', '(unallocated)', '(untagged)')) AS name,\n  SUM(cf.cost_usd * COALESCE(w.frac, 1)) AS cost\nFROM cost_facts cf\nLEFT JOIN (\n  SELECT etr.entity_type, etr.entity_id, etr.tag_id,\n         1.0 / COUNT(*) OVER (PARTITION BY etr.entity_type, etr.entity_id) AS frac\n  FROM entity_tags_resolved etr\n  JOIN tags tt ON tt.id = etr.tag_id AND tt.tag_key = 'work-type'\n) w ON w.entity_type = cf.entity_type AND w.entity_id = cf.entity_id\nLEFT JOIN tags t ON t.id = w.tag_id\nWHERE cf.timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  AND ('${product:raw}' = 'All' OR EXISTS (\n    SELECT 1 FROM entity_tags_resolved etr2\n    JOIN tags t2 ON t2.id = etr2.tag_id AND t2.tag_key = 'product' AND t2.tag_value = '${product:raw}'\n    WHERE etr2.entity_type = cf.entity_type AND etr2.entity_id = cf.entity_id))\n  AND ('${team:raw}' = 'All' OR EXISTS (\n    SELECT 1 FROM entity_tags_resolved etr3\n    JOIN tags t3 ON t3.id = etr3.tag_id AND t3.tag_key = 'team' AND t3.tag_value = '${team:raw}'\n    WHERE etr3.entity_type = cf.entity_type AND etr3.entity_id = cf.entity_id))\nGROUP BY name\nORDER BY cost DESC",
          "refId": "A"
        }
      ],
      "title": "Spend by Work-Type",
      "type": "bargauge"
    },
