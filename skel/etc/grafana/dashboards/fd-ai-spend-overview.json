          "format": "table",
          "rawSql": "SELECT ROUND(\n  100.0 * SUM(CASE WHEN ua.method != 'unallocated' THEN 1 ELSE 0 END) / COUNT(*), 1\n) AS attribution_pct\nFROM usage_attribution ua\nJOIN token_ledger tl USING (message_id)\nWHERE tl.timestamp BETWEEN $__timeFrom() AND DATE_SUB(NOW(), INTERVAL 24 HOUR)\n  AND ('${engineer:raw}' = 'All' OR tl.username = '${engineer:raw}')\n  AND ('${team:raw}' = 'All' OR tl.session_id IN (SELECT session_id FROM sessions WHERE team_name = '${team:raw}'))",
