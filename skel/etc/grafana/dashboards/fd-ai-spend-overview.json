    {
      "datasource": {
        "type": "mysql",
        "uid": "teamster-mysql"
      },
      "description": "scope: immediate ledger — % change vs prior equal window. Positive = more spend than prior period.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1,
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 5,
        "y": 3
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^delta_pct$/",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.1.1",
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "rawSql": "SELECT ROUND(\n  (curr.cost - prev.cost) / NULLIF(prev.cost, 0) * 100, 1\n) AS delta_pct\nFROM\n  (SELECT SUM(cost_usd) AS cost FROM token_ledger tl\n   WHERE $__timeFilter(tl.timestamp)\n     AND ('${engineer:raw}' = 'All' OR tl.username = '${engineer:raw}')\n  AND ('${team:raw}' = 'All' OR tl.session_id IN (SELECT session_id FROM sessions WHERE team_name = '${team:raw}'))) curr,\n  (SELECT SUM(cost_usd) AS cost FROM token_ledger tl\n   WHERE tl.timestamp >= DATE_SUB($__timeFrom(), INTERVAL TIMESTAMPDIFF(SECOND, $__timeFrom(), $__timeTo()) SECOND)\n     AND tl.timestamp < $__timeFrom()\n     AND ('${engineer:raw}' = 'All' OR tl.username = '${engineer:raw}')\n  AND ('${team:raw}' = 'All' OR tl.session_id IN (SELECT session_id FROM sessions WHERE team_name = '${team:raw}'))) prev",
          "refId": "A"
        }
      ],
      "title": "vs Prior Period",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "mysql",
        "uid": "teamster-mysql"
