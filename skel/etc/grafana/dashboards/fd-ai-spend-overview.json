          "format": "table",
          "rawSql": "SELECT\n  COALESCE(NULLIF(username, ''), '(unstamped)') AS engineer,\n  COUNT(DISTINCT session_id) AS sessions,\n  COUNT(*) AS messages,\n  ROUND(SUM(cost_usd), 2) AS cost,\n  ROUND(SUM(cost_usd) / GREATEST(DATEDIFF($__timeTo(), $__timeFrom()), 1), 2) AS cost_per_day\nFROM token_ledger tl\nWHERE $__timeFilter(tl.timestamp)\n  AND ('${engineer:raw}' = 'All' OR tl.username = '${engineer:raw}')\n  AND ('${team:raw}' = 'All' OR tl.session_id IN (SELECT session_id FROM sessions WHERE team_name = '${team:raw}'))\nGROUP BY username\nORDER BY cost DESC\nLIMIT 20",
