      "pluginVersion": "12.1.1",
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "teamster-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n  ROUND(SUM(cost_usd), 2) AS mtd,\n  ROUND(SUM(cost_usd) / GREATEST(DAY(NOW()), 1) * DAY(LAST_DAY(NOW())), 2) AS projected\nFROM token_ledger tl\nWHERE tl.timestamp >= DATE_FORMAT(NOW(), '%Y-%m-01')\n  AND tl.timestamp <= NOW()\n  AND ('${engineer:raw}' = 'All' OR tl.username = '${engineer:raw}')\n  AND ('${team:raw}' = 'All' OR tl.session_id IN (SELECT session_id FROM sessions WHERE team_name = '${team:raw}'))",
          "refId": "A"
        }
      ],
      "title": "Month-to-Date · Projected",
      "type": "stat"
    },
