global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    source: teamster
    monitor: {{ .Hostname }}
    environment: {{ .Env }}

scrape_configs:
  - job_name: 'teamster_hookd'
    static_configs:
      - targets: ['{{ .HookServerHost }}:{{ .HookServerPort }}']
    metrics_path: '/metrics'
